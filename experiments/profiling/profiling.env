# profiling.env — single source of run config for the profiling scripts (parsed by
# profiling_config.py), so the scripts don't each carry their own CONFIG block.  KEY=VALUE, like
# the regression's action_scripts/run_configs.env.
#
# An environment variable of the same name OVERRIDES a line here, e.g. for a one-off:
#     SIZE=512x512x512 python experiments/profiling/trace_back_projection.py
# (mirrors the regression's env-over-file precedence.)  Sizes are LxWxH labels; lists are
# comma-separated.  '#' starts a comment.

GEOMETRY=cone
OPS=forward,back

# Primary problem size — ASYMMETRIC on purpose: symmetric sizes (e.g. 256^3) can mask axis/stride
# effects.  200x208x160 is the dashboard's sinogram size and runs on both CPU and GPU.
SIZE=200x208x160

# Size sweep for the static / compile-time scripts (a smaller asymmetric size + the standard one).
SIZES=128x112x96,200x208x160

N_DEVICES=1
N_DEVICES_LIST=1,2          # device sweep for the trace scripts

WARMUP=2                    # untimed compile/warmup calls
TRACE_ITERS=3               # warm iterations captured per trace
STATIC_TRIALS=3             # warm timing trials (static_cone_back_kernels)
COMPILE_TRIALS=3            # warm trials (compile_time_projectors)
PROFILE_CALLS=2             # warm calls inside the ncu profiled region
TOP_N=30                    # rows shown in trace summaries
