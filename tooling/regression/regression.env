# tooling/regression/regression.env — harness infrastructure config for the nightly regression.
#
# CANONICAL HOME: this harness LIVES IN and RUNS FROM the mbirjax_metrics repo
# (github.com/gbuzzard/mbirjax_metrics) — edit it here directly.  Each nightly run makes a FRESH
# CLONE of metrics AND of mbirjax (see WORK_DIR), so remote harness/config/state changes are always
# picked up and NO per-node clone path is baked in (cluster, laptop, another user's home alike).
#
# The user-facing run knobs (which branches to track, install extras, env python) live in
# action_scripts/run_configs.env, sourced just below; edit those there.  Everything in THIS file is
# infrastructure (URLs, paths, credentials, schedule).  Sourced as bash.

# Run knobs (TRACKED_BRANCHES, INSTALL_EXTRAS_cpu/gpu, CONDA_PYTHON) — top-level + easy to edit.
source "$(dirname "${BASH_SOURCE[0]}")/../../action_scripts/run_configs.env"

ENABLED=1                       # master kill-switch (0 = installed but the wrapper exits immediately;
                                # prefer enable_nightly/disable_nightly — this stays low-profile)

# FIRE-ON-CHANGE: the wrapper wakes on POLL_SCHEDULE, reads each TRACKED_BRANCHES tip via
# `git ls-remote`, and measures a branch ONLY when it differs from the last-measured commit
# (metrics state/<plat>/).  (TRACKED_BRANCHES is set in run_configs.env.)
POLL_SCHEDULE="0 2 * * *"       # wakeup cadence (cron/launchd/scrontab); work happens only on a change

# ── Repos (URLs, not paths — the harness fresh-clones both each run) ──────────────────────────
METRICS_URL="https://github.com/gbuzzard/mbirjax_metrics.git"   # harness + golden + results + state
MBIRJAX_URL="https://github.com/cabouman/mbirjax.git"           # library under test (worktree source)
# Node-independent scratch for the per-run fresh clones + throwaway worktrees.  Uses $HOME so it
# works everywhere; point at large/fast scratch on the cluster if $HOME has a quota, e.g.
#   export MBIRJAX_REGRESSION_WORK="$SCRATCH/mbirjax_regression"   (honored below).
WORK_DIR="${MBIRJAX_REGRESSION_WORK:-$HOME/.mbirjax/regression}"

# ── Build / test ────────────────────────────────────────────────────────────────────────────
# INSTALL_EXTRAS_cpu / INSTALL_EXTRAS_gpu (pip extras per platform) are in run_configs.env.
# DEDICATED env — NOT your dev `mbirjax` env (the per-branch editable installs churn it and then
# delete the worktree).  Create once:  conda create -n mbirjax_regression python=3.x
# (CONDA_PYTHON — the version used if the harness must create this env — is in run_configs.env.)
CONDA_ENV="mbirjax_regression"
# The HARNESS's own python deps (NOT mbirjax's) — scaling_common imports these at module level.
# Installed into the dedicated env once per run (idempotent/fast if already present).
HARNESS_DEPS="matplotlib ruamel.yaml"
RUN_TESTS=1                     # 1 = run each branch's dev_scripts/run_tests.sh -> tests_<plat>_<date>.txt
                                # (.txt not .log: the metrics repo's .gitignore drops *.log)
TEST_CPU_DEVICES=4              # MBIRJAX_NUM_CPU_DEVICES for the test step (exercises the padding paths)

# ── Node preamble (cluster module loads + proxy) ──────────────────────────────────────────────
# A script the wrapper SOURCES (in BOTH phases) before any git/conda.  It must `module load` conda
# (+ cuda/cudnn on GPU) AND export HTTPS_PROXY/HTTP_PROXY (the compute node needs the proxy to reach
# github).  It is SOURCED, so it must be source-safe: module loads + exports only, NO `exit` and no
# `set -e` (either would abort the wrapper).  The path below exists only on the cluster, so the
# `[ -f ]` guard SKIPS it on the Mac automatically (conda is already on PATH there) — one shared
# value works for both nodes.  See cluster_preamble.sh.example for a ready-made one.
PREAMBLE_FILE="$HOME/load_conda_cuda.sh"

# ── Transport / notify ──────────────────────────────────────────────────────────────────────
MAX_PUSH_FILE_MB=25             # safety cap: the wrapper UNSTAGES any result/state file larger than
                                # this before committing, so a stray large artifact is never pushed
                                # (the .npy baselines are ~1 MB; this is a backstop, not a normal path)
# Unattended-push credential (cluster).  A git credential-STORE file (chmod 600) containing ONE
# line:  https://<github-user>:<fine-grained-PAT>@github.com   (NOT the bare token).  The wrapper
# wires `git config credential.helper "store --file=$TOKEN_FILE"`.  Skipped where the file is absent
# (so the Mac falls back to its keychain).  Never commit the file.  Create it once per cluster node.
TOKEN_FILE="$HOME/.config/mbirjax/metrics_credentials"
NOTIFY="buzzard@purdue.edu"     # cron/launchd MAILTO / slurm --mail-user; a hard-gate fail = real alert
