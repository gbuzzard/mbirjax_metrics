# run_configs.env — the run-time knobs for the nightly regression harness, kept at the top level so
# they are easy to find and edit.  The harness sources this (via tooling/regression/regression.env);
# because each run pulls the metrics repo before measuring, edits here propagate automatically.

# Branches to track (FIRE-ON-CHANGE): each is measured only when its remote tip moves.  The engine
# auto-detects sharding capability PER GEOMETRY, so an unported geometry is measured single-device:
# Note that the object below is used in a shell script, so strings separated by spaces is correct.
TRACKED_BRANCHES=("greg/shard_profiling" "prerelease" "main")

# pip extras for the editable install of each measured branch
# (pyproject: cuda12 = jax[cuda12]; test = pytest, pytest-xdist).
INSTALL_EXTRAS_cpu="test"
INSTALL_EXTRAS_gpu="cuda12,test"

# Python version for the dedicated regression conda env (CONDA_ENV in regression.env), used only if
# the harness has to create that env.
CONDA_PYTHON="3.11"

# Highest jax version we've ASSESSED for the GPU forward-projection perf regression (mbirjax excludes
# the known-bad 0.10.2 in its pyproject; see mbirjax/.claude/lessons.md).  Each nightly checks PyPI and
# warns in the log/email when a newer jax ships, so it gets re-tested with
# tooling/scaling_tests/measure_one_cell.py.  After reviewing a new release: bump this to it if good,
# or add it to the jax!=... exclusion in mbirjax/pyproject.toml if it regresses (then bump this too).
JAX_LAST_REVIEWED="0.10.2"

# ── Dependency canary (tooling/regression/dependency_canary_plan.md).  When a jax newer than the last
# one we measured ships, upgrade jax in the shared env and re-measure DEP_CANARY_BRANCH so a
# dependency-induced perf change (like the 0.10.2 slowdown) is CAUGHT and attributed, not just warned.
# DEFAULT OFF — enable only after reviewing the plan; it changes the fire logic + adds `_gNNNN` run files.
DEP_CANARY_ENABLED=1
DEP_CANARY_BRANCH="main"        # a stable, representative branch used as the fixed-code baseline
DEP_FULL_REFRESH_DAYS=14        # every N days, eager-upgrade ALL deps + re-measure the canary (a
                                # max-staleness timer, not change-detection — catches non-jax dep drift)

# ── macOS scheduling — the local time-of-day the Mac runs the nightly (launchd path).  The
# Linux/cluster path ignores this and uses POLL_SCHEDULE (regression.env) instead.
#   Format: 24-hour "HH:MM" (e.g. "09:00", "14:30").
#   IMPORTANT: pick a time the Mac is normally AWAKE.  A *scheduled wake from sleep* is a "dark wake",
#   during which launchd will NOT run a LaunchAgent — so a middle-of-the-night time on a laptop you
#   sleep simply never fires.  Re-run enable_nightly.sh after changing this (it reloads the agent).
MACOS_NIGHTLY_TIME="09:00"

# ── Cluster (SLURM) scheduling — used by enable_nightly.sh (scrontab) and nightly_regression.slurm.
# Ignored on macOS (launchd path).  fire-on-change means the job exits in seconds on a no-change
# night, so the walltime is just a ceiling (most of the cost is the actual measurement sweeps).
# QoS: "normal" works on the ai (H100) partition.  "standby" (idle-cycle, no allocation charge, 4h
# cap, preemptible) is NOT accepted on the ai partition here — if you find a standby-capable GPU
# partition, set SLURM_PARTITION + SLURM_QOS to it (and keep SLURM_WALLTIME <= that QoS's cap).
SLURM_ACCOUNT="bouman"
SLURM_PARTITION="ai"
SLURM_QOS="normal"
SLURM_GPUS_PER_NODE=4           # 4 H100s for the n=4 sharding sweep; drop to 2 to measure n=1,2 only
SLURM_NTASKS=56                 # cores
SLURM_WALLTIME="04:00:00"       # ceiling for a worst-case (all-branches-changed) night; ai MaxTime=14d
