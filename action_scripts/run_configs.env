# run_configs.env — the run-time knobs for the nightly regression harness, kept at the top level so
# they are easy to find and edit.  The harness sources this (via tooling/regression/regression.env);
# because each run pulls the metrics repo before measuring, edits here propagate automatically.

# Branches to track (FIRE-ON-CHANGE): each is measured only when its remote tip moves.  The engine
# auto-detects sharding capability PER GEOMETRY, so an unported geometry is measured single-device:
#   greg/conebeam_sharding — parallel + cone shard (full 1/2/4 sweep)
#   prerelease             — parallel shards; cone is n=1 only
#   main                   — no sharding API; everything n=1
TRACKED_BRANCHES=("greg/conebeam_sharding" "prerelease" "main")

# pip extras for the editable install of each measured branch
# (pyproject: cuda12 = jax[cuda12]; test = pytest, pytest-xdist).
INSTALL_EXTRAS_cpu="test"
INSTALL_EXTRAS_gpu="cuda12,test"

# Python version for the dedicated regression conda env (CONDA_ENV in regression.env), used only if
# the harness has to create that env.
CONDA_PYTHON="3.11"

# ── Cluster (SLURM) scheduling — used by enable_nightly.sh (scrontab) and nightly_regression.slurm.
# Ignored on macOS (launchd path).  fire-on-change means the job exits in seconds on a no-change
# night, so the walltime is just a ceiling.  QoS "standby" runs on idle cycles and does NOT draw
# down the account — at the cost of lower priority, preemptibility, and a shorter walltime cap;
# switch to "normal" for higher priority + longer walltime (charges the allocation).
SLURM_ACCOUNT="bouman"
SLURM_PARTITION="ai"
SLURM_QOS="standby"
SLURM_GPUS_PER_NODE=4           # 4 H100s for the n=4 sharding sweep; drop to 2 to measure n=1,2 only
SLURM_NTASKS=56                 # cores
SLURM_WALLTIME="04:00:00"       # ceiling for a worst-case (all-branches-changed) night
